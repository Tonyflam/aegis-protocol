# ================================
# Aegis Protocol - Environment Variables
# ================================

# Deployer private key (WITHOUT 0x prefix)
PRIVATE_KEY=your_private_key_here

# BSCScan API key for contract verification (optional)
BSCSCAN_API_KEY=your_bscscan_api_key

# ─── AI Provider API Keys (choose one) ───
# Groq (recommended — free tier, Llama 3.3 70B)
GROQ_API_KEY=your_groq_api_key
# OpenAI (alternative)
OPENAI_API_KEY=your_openai_api_key
# AI Model override (optional)
# AI_MODEL=llama-3.3-70b-versatile

# BSC RPC URLs (optional, defaults provided)
BSC_TESTNET_RPC=https://data-seed-prebsc-1-s1.binance.org:8545
BSC_MAINNET_RPC=https://bsc-dataseed1.binance.org

# Frontend
NEXT_PUBLIC_BSC_TESTNET_RPC=https://data-seed-prebsc-1-s1.binance.org:8545
NEXT_PUBLIC_CHAIN_ID=97

# ─── Agent Configuration ───
# Contract addresses (BSC Testnet — set after deployment, or use defaults from deployment.json)
VAULT_ADDRESS=0x15Ef23024c2b90beA81E002349C70f0C2A09433F
REGISTRY_ADDRESS=0x7908c25C63AbAB47cb82bE50DBD874ED807EE8fF
LOGGER_ADDRESS=0x874d78947bd660665de237b16Ca05cd39b7feF6f
TOKEN_GATE_ADDRESS=0x672c5cC370085c3c6B5bcf2870e1A0Aa62Ff3D69

# Agent runtime settings
AGENT_ID=0
DRY_RUN=true              # Set to false for mainnet real execution
POLL_INTERVAL=30000       # 30 seconds
AGENT_RISK_THRESHOLD=75   # Trigger protection at 75+ risk

# ─── $UNIQ Token ───
UNIQ_TOKEN_ADDRESS=0xdd5f3e8c2cfc8444fac46744d0a4a85df03d7777

# ─── Mainnet Deployment (Phase 3) ───
# MAINNET_VAULT_ADDRESS=
# MAINNET_REGISTRY_ADDRESS=
# MAINNET_LOGGER_ADDRESS=
# MAINNET_TOKEN_GATE_ADDRESS=
