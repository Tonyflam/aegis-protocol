# ================================
# Aegis Protocol - Environment Variables
# ================================

# Deployer private key (WITHOUT 0x prefix)
PRIVATE_KEY=your_private_key_here

# BSCScan API key for contract verification (optional)
BSCSCAN_API_KEY=your_bscscan_api_key

# ─── AI Provider API Keys (choose one) ───
# Groq (recommended — free tier, Llama 3.3 70B)
GROQ_API_KEY=your_groq_api_key
# OpenAI (alternative)
OPENAI_API_KEY=your_openai_api_key
# AI Model override (optional)
# AI_MODEL=llama-3.3-70b-versatile

# BSC RPC URLs
# BSC_RPC is the preferred single runtime URL for the agent.
BSC_RPC=https://bsc-dataseed1.binance.org
BSC_TESTNET_RPC=https://data-seed-prebsc-1-s1.binance.org:8545
BSC_MAINNET_RPC=https://bsc-dataseed1.binance.org

# Frontend
NEXT_PUBLIC_BSC_TESTNET_RPC=https://data-seed-prebsc-1-s1.binance.org:8545
NEXT_PUBLIC_CHAIN_ID=97

# ─── Agent Configuration ───
# Contract addresses (BSC Testnet examples — replace after deployment)
VAULT_ADDRESS=0x15Ef23024c2b90beA81E002349C70f0C2A09433F
REGISTRY_ADDRESS=0x7908c25C63AbAB47cb82bE50DBD874ED807EE8fF
LOGGER_ADDRESS=0x874d78947bd660665de237b16Ca05cd39b7feF6f
TOKEN_GATE_ADDRESS=0x672c5cC370085c3c6B5bcf2870e1A0Aa62Ff3D69
AGENT_OPERATOR_ADDRESS=0xYourProductionOperatorWallet
SCANNER_OPERATOR_ADDRESS=0xYourScannerOperatorWallet

# Agent runtime settings
AGENT_ID=0
DRY_RUN=true              # Set to false for mainnet real execution
POLL_INTERVAL=30000       # 30 seconds
AGENT_RISK_THRESHOLD=75   # Trigger protection at 75+ risk

# ─── $UNIQ Token ───
UNIQ_TOKEN_ADDRESS=0xdd5f3e8c2cfc8444fac46744d0a4a85df03d7777

# ─── Mainnet Deployment ───
# Before running: set AGENT_OPERATOR_ADDRESS so the live agent wallet is authorized at deploy time.
# After running: npx hardhat run scripts/deploy-mainnet.ts --network bscMainnet
# Copy addresses from deployment-mainnet.json and set:
# NEXT_PUBLIC_CHAIN_ID=56
# BSC_RPC=https://bsc-dataseed1.binance.org
# NEXT_PUBLIC_VAULT_ADDRESS=0x9f605D46b07d9BBBF18528BE4D8546A993c30C06
# NEXT_PUBLIC_REGISTRY_ADDRESS=0xb29f289D89921Ea784c8E8FDc04ced20cEcbE0B9
# NEXT_PUBLIC_LOGGER_ADDRESS=0x51Be618E3CA0b0B19FA0cC6c10960fF62783Da86
# NEXT_PUBLIC_TOKEN_GATE_ADDRESS=0xabbd2E13d5eda2D75D1599A7539a3083dfaba715
# NEXT_PUBLIC_SCANNER_ADDRESS=0x26D61a9cE682c051cD8DA343acE97a9C88Cf2b5D
# NEXT_PUBLIC_VENUS_ADDRESS=0xA07c5b74C9B40447a954e1466938b865b6BBea36
# NEXT_PUBLIC_USDT_ADDRESS=0x55d398326f99059fF775485246999027B3197955
# VAULT_ADDRESS=0x9f605D46b07d9BBBF18528BE4D8546A993c30C06
# REGISTRY_ADDRESS=0xb29f289D89921Ea784c8E8FDc04ced20cEcbE0B9
# LOGGER_ADDRESS=0x51Be618E3CA0b0B19FA0cC6c10960fF62783Da86
# TOKEN_GATE_ADDRESS=0xabbd2E13d5eda2D75D1599A7539a3083dfaba715

# ─── Telegram Alerts ───
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# ─── Guardian Cron (background monitoring) ───
# Set a random secret to protect the /api/guardian/cron endpoint
CRON_SECRET=your_random_secret_here
