# ═══════════════════════════════════════════════════════════════
# Aegis Protocol — Environment Variables
# Copy this file to .env.local and fill in your values
# ═══════════════════════════════════════════════════════════════

# ─── Required: Redis (Upstash) ────────────────────────────────
# Used for: token scan cache, Telegram subscriptions, rate limiting
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Required: AI (Groq) ─────────────────────────────────────
# Used for: Gold tier LLM-powered wallet analysis
# Get a free key at https://console.groq.com
GROQ_API_KEY=

# ─── Required: Telegram Bot ──────────────────────────────────
# Used for: Push alerts to subscribers
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# ─── Required: Cron Security ─────────────────────────────────
# Protects /api/guardian/cron from unauthorized access
# Generate with: openssl rand -hex 32
CRON_SECRET=

# ─── Network Config ──────────────────────────────────────────
# "56" for BSC Mainnet, "97" for BSC Testnet
NEXT_PUBLIC_CHAIN_ID=56

# Custom RPC (optional — defaults based on CHAIN_ID)
# BSC_RPC=https://bsc-dataseed1.binance.org

# ─── Contract Addresses ──────────────────────────────────────
# Mainnet addresses (deployed 2026-04-22)
NEXT_PUBLIC_VAULT_ADDRESS=0xb66b1d67d156Fb7FC21B6cb9Be573C118C37e4f4
NEXT_PUBLIC_REGISTRY_ADDRESS=0xb29f289D89921Ea784c8E8FDc04ced20cEcbE0B9
NEXT_PUBLIC_LOGGER_ADDRESS=0x51Be618E3CA0b0B19FA0cC6c10960fF62783Da86
NEXT_PUBLIC_TOKEN_GATE_ADDRESS=0xabbd2E13d5eda2D75D1599A7539a3083dfaba715
NEXT_PUBLIC_SCANNER_ADDRESS=0x26D61a9cE682c051cD8DA343acE97a9C88Cf2b5D
NEXT_PUBLIC_UNIQ_TOKEN_ADDRESS=0xdd5f3e8c2cfc8444fac46744d0a4a85df03d7777
NEXT_PUBLIC_VENUS_ADDRESS=0xA07c5b74C9B40447a954e1466938b865b6BBea36
NEXT_PUBLIC_USDT_ADDRESS=0x55d398326f99059fF775485246999027B3197955

# ─── Agent Config (for agent/ directory only) ────────────────
# PRIVATE_KEY=           # 64-char hex, no 0x prefix
# VAULT_ADDRESS=0x...
# REGISTRY_ADDRESS=0x...
# LOGGER_ADDRESS=0x...
# AGENT_ID=0
# DRY_RUN=true           # Set to "false" for live execution
# POLL_INTERVAL=30000    # Agent cycle interval in ms
